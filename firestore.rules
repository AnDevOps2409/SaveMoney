rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users collection
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      match /wallets/{walletId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /categories/{categoryId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /transactions/{transactionId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /budgets/{budgetId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /savings/{savingId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // ===== Families collection =====
    match /families/{familyId} {
      // Đọc: cho phép auth users đọc để có thể query bằng inviteCode
      allow read: if request.auth != null;

      // Tạo mới: phải đăng nhập
      allow create: if request.auth != null;

      // Cập nhật (join/leave): phải đăng nhập
      allow update: if request.auth != null;

      // Xóa: chỉ người tạo
      allow delete: if request.auth != null &&
        resource.data.createdBy == request.auth.uid;

      // Transactions trong family
      match /transactions/{transactionId} {
        // Đọc: là thành viên của family
        allow read: if request.auth != null &&
          request.auth.uid in get(/databases/$(database)/documents/families/$(familyId)).data.memberIds;

        // Tạo: là thành viên + createdBy.userId phải là uid của mình
        allow create: if request.auth != null &&
          request.resource.data.createdBy.userId == request.auth.uid;

        // Xóa: chỉ người tạo bản ghi
        allow delete: if request.auth != null &&
          resource.data.createdBy.userId == request.auth.uid;

        // Update: chỉ người tạo bản ghi
        allow update: if request.auth != null &&
          resource.data.createdBy.userId == request.auth.uid;
      }

      // Budgets trong family
      match /budgets/{budgetId} {
        allow read, write: if request.auth != null &&
          request.auth.uid in get(/databases/$(database)/documents/families/$(familyId)).data.memberIds;
      }

      // Savings trong family
      match /savings/{savingId} {
        allow read, write: if request.auth != null &&
          request.auth.uid in get(/databases/$(database)/documents/families/$(familyId)).data.memberIds;
      }

      // Wallets trong family
      match /wallets/{walletId} {
        allow read, write: if request.auth != null &&
          request.auth.uid in get(/databases/$(database)/documents/families/$(familyId)).data.memberIds;
      }
    }
  }
}
